{
  "dispatch": {
    "enabled": true,
    "timeoutSeconds": 8,
    "retries": 1
  },
  "jobs": [
    {
      "id": "finance-weekly",
      "name": "Finance Weekly Cost Digest",
      "enabled": true,
      "frequency": "weekly",
      "granularity": "weekly",
      "metrics": ["total_cost", "active_models", "avg_cost_per_model"],
      "models": ["gpt-5", "o3"],
      "formats": ["json", "csv"],
      "allowedRoles": ["admin", "analyst"],
      "layout": {
        "title": "Finance Weekly",
        "sections": ["summary", "forecast", "alerts", "model_breakdown"]
      },
      "recipients": [
        {
          "channel": "slack",
          "target": "https://hooks.slack.com/services/xxx/yyy/zzz"
        },
        {
          "channel": "discord",
          "target": "https://discord.com/api/webhooks/..."
        }
      ]
    }
  ]
}
